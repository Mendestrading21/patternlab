{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PatternLab Lesson",
  "type": "object",
  "required": [
    "id",
    "slug",
    "title",
    "skillId",
    "steps",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "skillId": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "difficulty": {
      "enum": [
        "beginner",
        "intermediate",
        "advanced"
      ]
    },
    "estimatedMinutes": {
      "type": "integer",
      "minimum": 1
    },
    "steps": {
      "type": "array",
      "minItems": 1
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "enum": [
        "raw_imported",
        "normalized",
        "draft",
        "needs_review",
        "approved",
        "published",
        "archived"
      ]
    },
    "legacy": {
      "type": "object",
      "properties": {
        "legacySource": {
          "type": "string"
        },
        "legacyTable": {
          "type": "string"
        },
        "legacyId": {
          "type": [
            "string",
            "integer"
          ]
        },
        "sourceHash": {
          "type": "string"
        },
        "migrationVersion": {
          "type": "integer"
        }
      }
    }
  }
}
