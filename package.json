{
  "name": "patternlab",
  "type": "module",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=24.0.0 <25",
    "npm": ">=11.0.0 <12"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~57.0.7",
    "expo-constants": "~57.0.6",
    "expo-image": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.7",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "ajv": "^8.20.0",
    "eslint": "^9.39.5",
    "eslint-config-expo": "~57.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "validate:content": "node ./scripts/validate-content/index.mjs",
    "import:app": "node ./scripts/import-app/index.mjs",
    "prepare:web": "node ./scripts/prepare-web-assets.mjs",
    "finalize:web": "node ./scripts/finalize-web-build.mjs",
    "verify:deployment": "node ./scripts/verify-deployment-config.mjs",
    "verify:brand": "node ./scripts/verify-brand-assets.mjs",
    "verify:docs": "node ./scripts/verify-doc-links.mjs",
    "verify:web": "node ./scripts/verify-web-build.mjs",
    "release:check": "node ./scripts/release-check.mjs && npm run verify:deployment && npm run verify:brand && npm run verify:docs",
    "build:web": "npm run prepare:web && expo export --platform web && npm run finalize:web && npm run verify:web",
    "check": "npm run lint && npm run typecheck && npm test -- --runInBand && npm run validate:content && npm run release:check && npm run build:web"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.setup.cjs"
    ],
    "moduleNameMapper": {
      "^@/assets/(.*)$": "<rootDir>/assets/$1",
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "testMatch": [
      "**/src/**/*.test.ts",
      "**/src/**/*.test.tsx"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|lottie-react-native|@react-native-async-storage))"
    ]
  },
  "private": true
}
