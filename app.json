{
  "expo": {
    "name": "Trademy",
    "slug": "patternlab",
    "version": "1.0.0",
    "description": "Apprends à lire les marchés, quelques minutes par jour. Application éducative gamifiée — aucun conseil financier.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "patternlab",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0D16",
    "primaryColor": "#9270F0",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.patternlab.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.patternlab.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0D16",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0D16",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 112
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
