{
  "expo": {
    "name": "PatternLab",
    "slug": "patternlab",
    "version": "1.0.0",
    "description": "Apprends à lire les marchés, quelques minutes par jour. Application éducative gamifiée — aucun conseil financier.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "patternlab",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B1119",
    "primaryColor": "#26C281",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.patternlab.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.patternlab.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B1119",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B1119",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "baseUrl": "/patternlab"
    }
  }
}
